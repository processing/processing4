public class interface_test extends PApplet {
enum Direction {
  NORTH, SOUTH, EAST, WEST
}
  public void setup() {
    size(100, 100);
    Direction d = Direction.NORTH;
    println(d);
  }
  public void draw() {
    background(255);
  }
    static public void main(String[] passedArgs) {
        String[] appletArgs = new String[] { "interface_test" };
        if (passedArgs != null) {
            PApplet.main(concat(appletArgs, passedArgs));
        } else {
            PApplet.main(appletArgs);
        }
    }
}